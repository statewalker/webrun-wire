    "@libp2p/identify": "^3.0.0",
    "@libp2p/webrtc": "^5.0.0",
    "@libp2p/websockets": "^9.0.0",
    "@multiformats/multiaddr": "^12.0.0",
    "@statewalker/webrun-http-port": "workspace:*",
    "@statewalker/webrun-port-libp2p": "workspace:*",
