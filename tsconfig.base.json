{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@statewalker/webrun-http-browser": ["./packages/webrun-http-browser/src"],
      "@statewalker/webrun-http-browser/sw": ["./packages/webrun-http-browser/src/sw"],
      "@statewalker/webrun-http-streams": ["./packages/webrun-http-streams/src"],
      "@statewalker/webrun-rpc-http": ["./packages/webrun-rpc-http/src"],
      "@statewalker/webrun-site-builder": ["./packages/webrun-site-builder/src"],
      "@statewalker/webrun-site-host": ["./packages/webrun-site-host/src"],
      "@statewalker/webrun-streams": ["./packages/webrun-streams/src"],
      "@statewalker/webrun-streams-conformance": ["./packages/webrun-streams-conformance/src"],
      "@statewalker/webrun-streams-libp2p": ["./packages/webrun-streams-libp2p/src"],
      "@statewalker/webrun-streams-livekit": ["./packages/webrun-streams-livekit/src"],
      "@statewalker/webrun-streams-peerjs": ["./packages/webrun-streams-peerjs/src"],
      "@statewalker/webrun-streams-port": ["./packages/webrun-streams-port/src"],
      "@statewalker/webrun-streams-webrtc": ["./packages/webrun-streams-webrtc/src"],
      "@statewalker/webrun-streams-ws": ["./packages/webrun-streams-ws/src"]
    }
  }
}
