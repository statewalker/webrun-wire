{
  "name": "@statewalker/webrun-port-libp2p",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Bridge a libp2p Stream to a MessagePort. Adapter in the webrun-port-* family.",
  "homepage": "https://github.com/statewalker/webrun-wire",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:statewalker/webrun-wire.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rimraf dist && rolldown -c && tsc --emitDeclarationOnly --declaration",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "lint": "biome check src tests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@statewalker/webrun-port-core": "workspace:*"
  },
  "peerDependencies": {
    "@libp2p/interface": "^2.0.0",
    "libp2p": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "libp2p": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chainsafe/libp2p-noise": "^16.0.0",
    "@chainsafe/libp2p-yamux": "^7.0.0",
    "@libp2p/interface": "^2.2.0",
    "@libp2p/mplex": "^11.0.0",
    "@libp2p/tcp": "^10.0.0",
    "@statewalker/webrun-port-conformance": "workspace:*",
    "@statewalker/webrun-ports": "workspace:*",
    "@types/node": "catalog:",
    "libp2p": "^2.4.0",
    "rimraf": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
